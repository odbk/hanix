#!/usr/bin/env bash
# Elige un tema de Plymouth aleatorio y reconstruye el sistema.
FLAKE="$(dirname "$(readlink -f "$0")")"
CONFIG="$FLAKE/shared/configuration.nix"

THEMES=(
    glitch
    cybernetic
    circuit
    hexagon_hud
    hexagon_dots
    cyanide
    blockchain
    dna
    cuts
    hexa_retro
)

THEME="${THEMES[$RANDOM % ${#THEMES[@]}]}"
echo "Tema seleccionado: $THEME"

sed -i "s/theme = \".*\";/theme = \"$THEME\";/" "$CONFIG"

"$FLAKE/rebuild" boot
echo "Listo — el nuevo tema se verá en el próximo reinicio."
