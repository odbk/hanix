#!/usr/bin/env bash
# Ejecuta nixos-rebuild desde cualquier directorio.
# Uso: ./rebuild [switch|boot|test|dry-run] [argumentos extra]
FLAKE="$(dirname "$(readlink -f "$0")")"
ACTION="${1:-switch}"
shift 2>/dev/null

# Copia el hardware config local si no existe en el repo
if [ ! -f "$FLAKE/hardware-configuration.nix" ]; then
    echo "Copiando hardware-configuration.nix desde /etc/nixos..."
    cp /etc/nixos/hardware-configuration.nix "$FLAKE/hardware-configuration.nix"
fi

# Nix flakes solo ven ficheros git-tracked — stagear sin commitear
git -C "$FLAKE" add -f hardware-configuration.nix 2>/dev/null

exec sudo nixos-rebuild "$ACTION" --flake "$FLAKE" "$@"
